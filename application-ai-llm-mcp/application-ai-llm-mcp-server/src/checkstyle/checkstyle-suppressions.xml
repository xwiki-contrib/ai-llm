<!DOCTYPE suppressions PUBLIC
    "-//Puppy Crawl//DTD Suppressions 1.0//EN"
    "http://www.puppycrawl.com/dtds/suppressions_1_0.dtd">

<suppressions>
  <!-- XWikiMCPServerManager is the module's composition root: it bridges the XWiki component world
       (lifecycle, configuration, user resolution) to the MCP SDK world (transport, server builder,
       schema types) and hosts the per-call middleware. Referencing many classes is intrinsic to that
       role, and working around the cap has repeatedly forced worse code (dropping a useful catch
       clause, inlining helpers). -->
  <suppress checks="ClassFanOutComplexity"
      files="org[/\\]xwiki[/\\]contrib[/\\]llm[/\\]mcp[/\\]internal[/\\]XWikiMCPServerManager\.java"/>
  <!-- MCPGetTreeTool models its two navigation modes with seven small nested records and composes the
       shared doors (row query, document access, wiki reach) with the MCP tool contract types. After the
       row-query pipeline was extracted into MCPRowQuery (LLMAI-153), the remaining references are the
       tool's own record shape plus intrinsic contract types - verified by enumeration, twice; every
       further reduction traded a well-named type for worse code. -->
  <suppress checks="ClassFanOutComplexity"
      files="org[/\\]xwiki[/\\]contrib[/\\]llm[/\\]mcp[/\\]internal[/\\]MCPGetTreeTool\.java"/>
</suppressions>
