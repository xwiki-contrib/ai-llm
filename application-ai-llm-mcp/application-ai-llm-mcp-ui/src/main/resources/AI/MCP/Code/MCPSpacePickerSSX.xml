    <property>
      <code>.mcp-space-picker {
  margin-bottom: 1.5em;
}

/* Separate the configuration form (its Save button is the last element) from the farm dashboard section below it. */
#mcp-server-config {
  margin-bottom: 2em;
}

.mcp-space-picker .mcp-chip-section {
  margin-bottom: 1em;
}

.mcp-space-picker .mcp-chip-section .label {
  display: block;
  margin-bottom: 0.4em;
  padding: 0;
  font-size: 0.85em;
  font-weight: bold;
  color: #333;
  background: none;
  text-align: left;
  white-space: normal;
}

.mcp-space-picker .mcp-chip-list {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.4em;
}

.mcp-space-picker .mcp-chip {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  padding: 0.15em 0.5em;
  background-color: #eee;
  border: 1px solid #ddd;
  border-radius: 12px;
  font-size: 0.9em;
  line-height: 1.6;
  vertical-align: middle;
}

.mcp-space-picker .mcp-chip-label {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mcp-space-picker .mcp-chip-remove {
  margin-left: 0.35em;
  padding: 0 0.2em;
  border: none;
  background: none;
  color: #777;
  font-size: 1.1em;
  line-height: 1;
  cursor: pointer;
}

.mcp-space-picker .mcp-chip-remove:hover,
.mcp-space-picker .mcp-chip-remove:focus {
  color: #333;
}

.mcp-space-picker .mcp-chip-empty {
  color: #777;
  font-style: italic;
}</code>
